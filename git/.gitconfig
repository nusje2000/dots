[core]
        commentchar = ";"
[user]
        email = maarten.nusteling@gmail.com
        name = Maarten Nusteling
[init]
        defaultBranch = main
[push]
        autoSetupRemote = true
        default = current
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
