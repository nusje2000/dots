{
    "$schema": "/Users/maartenn/.local/share/nvim/mason/packages/phpactor/phpactor.schema.json",
    "indexer.exclude_patterns": [
        "/vendor/**/Tests/**/*",
        "/vendor/**/tests/**/*",
        "/var/cache/**/*",
        "/vendor/composer/**/*"
    ],
    "language_server_phpstan.enabled": true,
    "language_server_phpstan.bin": "%config%/phpstan",
    "language_server_phpstan.level": "max",
    "php_code_sniffer.enabled": true,
    "php_code_sniffer.bin": "%config%/phpcs",
    "indexer.stub_paths": ["%config%/phpstorm-stubs"],
    "worse_reflection.stub_dir": "%config%/phpstorm-stubs"
}
